# Copier en .env et remplir les valeurs

# Site
SITE_URL=https://am-electricite.fr
WEB3FORMS_KEY=votre-cle-web3forms

# Umami Analytics (cree en wf-10 lors du deploiement)
UMAMI_WEBSITE_ID=

# CMS maison (panel /admin)
CMS_PASSWORD=mot-de-passe-client-a-definir
CMS_SESSION_SECRET=chaine-aleatoire-de-32-caracteres-minimum
CMS_REPO=mavailable/site-am-electricite
CMS_BRANCH=dev
GITHUB_TOKEN=ghp_xxx_token_github_fine_grained_avec_scope_contents_write
