---
/**
 * Section Services — fond blanc, grille 2×3 de cards avec icônes.
 * Chaque card : fond blanc, bordure neutral-200, hover ombre.
 * Texte : primary-900 titres, neutral-700 corps. (guide design-system.md)
 */
import { getServices } from '@data/content';

const services = getServices();

/** Map icon name → inline SVG path */
const iconPaths: Record<string, string> = {
  Zap: 'M13 2L3 14h9l-1 10 10-12h-9l1-10z',
  RefreshCw: 'M23 4v6h-6M1 20v-6h6M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15',
  ShieldCheck: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10zM9 12l2 2 4-4',
  Snowflake: 'M12 2v20M17.66 6.34l-11.32 11.32M22 12H2M17.66 17.66L6.34 6.34M12 2l3 3M12 2L9 5M12 22l3-3M12 22l-3-3M22 12l-3 3M22 12l-3-3M2 12l3 3M2 12l3-3',
  Wifi: 'M5 12.55a11 11 0 0114.08 0M1.42 9a16 16 0 0121.16 0M8.53 16.11a6 6 0 016.95 0M12 20h.01',
  Wrench: 'M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z',
};
---

<section id="services" class="bg-white py-16 md:py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header — left-aligned for variety -->
    <div class="max-w-2xl mb-12">
      <span class="font-body font-medium text-accent-700 text-sm tracking-wide uppercase">Ce que nous faisons</span>
      <h2 class="font-heading font-semibold text-primary-900 text-3xl md:text-4xl mt-2 mb-4">Nos prestations</h2>
      <p class="text-neutral-700 text-lg leading-relaxed">
        Du tableau électrique à la climatisation, une offre complète pour les particuliers et les professionnels.
      </p>
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service) => (
        <article class="group bg-white border border-neutral-200 rounded-xl p-6 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
          <!-- Icon -->
          <div class="w-12 h-12 bg-primary-50 rounded-lg flex items-center justify-center mb-4 group-hover:bg-primary-100 transition-colors">
            <svg
              class="w-6 h-6 text-primary-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d={iconPaths[service.icon] || iconPaths.Zap} />
            </svg>
          </div>

          <h3 class="font-heading font-semibold text-primary-900 text-lg mb-2">{service.title}</h3>
          <p class="text-neutral-700 text-sm leading-relaxed">{service.description}</p>
        </article>
      ))}
    </div>

    <!-- CTA integrated in a subtle bar -->
    <div class="mt-12 bg-primary-50 rounded-xl p-6 md:p-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-primary-900 font-medium text-center sm:text-left">
        Un projet en tête ? Décrivez-le nous pour recevoir un devis adapté.
      </p>
      <a
        href="#contact"
        data-track="cta"
        class="inline-flex items-center justify-center bg-accent-400 text-secondary-950 font-bold text-sm py-3 px-6 rounded-lg hover:bg-accent-500 transition-all min-h-[44px] shrink-0"
      >
        Demander un devis
      </a>
    </div>

  </div>
</section>
