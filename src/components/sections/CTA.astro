---
/**
 * Bannière CTA — fond primary-950 (rappel du Hero mais plus compact).
 * Texte : white titre, neutral-100 sous-titre.
 * Bouton : secondary-950 sur accent-400 (10.13:1).
 */
import { getSiteInfo } from '@data/content';

const siteInfo = getSiteInfo();
---

<section class="bg-primary-950 py-14 md:py-20 relative overflow-hidden" aria-label="Appel à l'action">
  <!-- Subtle decorative gradient -->
  <div class="absolute inset-0 bg-gradient-to-r from-primary-950 via-primary-900 to-primary-950 opacity-50"></div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="font-heading font-semibold text-white text-3xl md:text-4xl mb-4">
      Un projet électrique en tête ?
    </h2>
    <p class="text-neutral-300 text-lg max-w-2xl mx-auto mb-8">
      Décrivez-nous votre besoin et recevez un devis gratuit et personnalisé sous 24 heures. Particulier ou professionnel, Anthony vous accompagne.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#contact"
        data-track="cta"
        class="inline-flex items-center justify-center bg-accent-400 text-secondary-950 font-bold py-3 px-8 rounded-lg hover:bg-accent-500 transition-all min-h-[44px] text-lg hover:shadow-lg hover:-translate-y-0.5"
      >
        Demander mon devis gratuit
      </a>
      <a
        href={`tel:+${siteInfo.whatsapp}`}
        class="inline-flex items-center gap-2 text-neutral-300 hover:text-white transition-colors font-medium"
        aria-label={`Appeler le ${siteInfo.phone}`}
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        {siteInfo.phone}
      </a>
    </div>
  </div>
</section>
