---
/**
 * Bande de chiffres clés — fond ambre (accent-400) pour contraste fort avec le Hero sombre au-dessus.
 * Texte en secondary-950 sur accent-400 = 10.13:1 (AA).
 */
const stats = [
  { value: '12+', label: 'Années d\'expérience', icon: 'calendar' },
  { value: '2', label: 'Domaines de compétence', icon: 'layers' },
  { value: '100%', label: 'Devis gratuits', icon: 'check' },
];
---

<section class="bg-accent-400 py-8 md:py-10" aria-label="Chiffres clés">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-8 sm:gap-4">
      {stats.map((stat, i) => (
        <div class="flex items-center gap-4 text-center sm:text-left">
          {i > 0 && (
            <div class="hidden sm:block w-px h-12 bg-secondary-950/20 -ml-2 mr-2"></div>
          )}
          <div>
            {stat.icon === 'calendar' && (
              <svg class="w-8 h-8 text-secondary-800 mx-auto sm:mx-0 mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" /><path d="M16 2v4M8 2v4M3 10h18"/></svg>
            )}
            {stat.icon === 'layers' && (
              <svg class="w-8 h-8 text-secondary-800 mx-auto sm:mx-0 mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 2l10 6.5v7L12 22 2 15.5v-7L12 2zM12 22v-6.5M22 8.5l-10 7-10-7"/></svg>
            )}
            {stat.icon === 'check' && (
              <svg class="w-8 h-8 text-secondary-800 mx-auto sm:mx-0 mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            )}
          </div>
          <div>
            <p class="font-heading font-bold text-secondary-950 text-3xl md:text-4xl leading-none">{stat.value}</p>
            <p class="text-secondary-900 font-medium text-sm mt-1">{stat.label}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
