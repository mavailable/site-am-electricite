---
/**
 * Témoignages — fond primary-800 (section sombre, différente du Hero en primary-950).
 * Cards blanches sur fond sombre pour le contraste inversé.
 * Texte cards : primary-900 titre, neutral-700 corps (cards blanches).
 * Texte section : white titre, neutral-100 sous-titre.
 */
import { getTestimonials } from '@data/content';

const testimonials = getTestimonials();

/** Generate initials from name */
function getInitials(name: string): string {
  return name
    .split(' ')
    .map((n) => n[0])
    .join('')
    .toUpperCase()
    .slice(0, 2);
}
---

<section class="bg-primary-800 py-16 md:py-24" aria-label="Témoignages clients">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-12">
      <span class="font-body font-medium text-accent-300 text-sm tracking-wide uppercase">Avis clients</span>
      <h2 class="font-heading font-semibold text-white text-3xl md:text-4xl mt-2 mb-3">Ce que disent nos clients</h2>
      <p class="text-neutral-100 text-base max-w-lg mx-auto">
        Des interventions sur le bassin grenoblois qui parlent d'elles-mêmes.
      </p>
    </div>

    <!-- Testimonial cards — horizontal on desktop, stacked on mobile -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {testimonials.map((t) => (
        <article class="bg-white rounded-xl p-6 shadow-lg flex flex-col">
          <!-- Stars -->
          <div class="flex gap-0.5 mb-4" aria-label="5 étoiles sur 5">
            {[1, 2, 3, 4, 5].map(() => (
              <svg class="w-5 h-5 text-accent-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class="text-neutral-700 text-sm leading-relaxed mb-6 flex-1">
            &laquo;&nbsp;{t.quote}&nbsp;&raquo;
          </blockquote>

          <!-- Author -->
          <div class="flex items-center gap-3 pt-4 border-t border-neutral-200">
            <div class="w-10 h-10 bg-primary-100 rounded-full flex items-center justify-center shrink-0">
              <span class="text-primary-700 font-bold text-sm">{getInitials(t.name)}</span>
            </div>
            <div>
              <p class="text-primary-900 font-medium text-sm">{t.name}</p>
              <p class="text-neutral-500 text-xs">{t.context}</p>
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
