---
/**
 * FAQ — fond neutral-50 (alternance avec sections blanches).
 * Accordéon natif <details>/<summary> (zéro JS, accessible).
 * Layout : deux colonnes — texte intro gauche + accordéon droite (asymétrique).
 */
import { getFaq } from '@data/content';

const faqItems = getFaq();
---

<section id="faq" class="bg-neutral-50 py-16 md:py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-16">

      <!-- Left column — intro text (2/5) -->
      <div class="lg:col-span-2">
        <span class="font-body font-medium text-accent-700 text-sm tracking-wide uppercase">FAQ</span>
        <h2 class="font-heading font-semibold text-primary-900 text-3xl md:text-4xl mt-2 mb-4">Questions fréquentes</h2>
        <p class="text-neutral-700 text-base leading-relaxed mb-6">
          Vous avez une question sur nos services, notre zone d'intervention ou nos tarifs ? Consultez les réponses ci-contre, ou contactez-nous directement.
        </p>
        <a
          href="#contact"
          class="inline-flex items-center gap-2 text-primary-700 hover:text-primary-600 font-medium transition-colors"
        >
          Poser une autre question
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>

      <!-- Right column — accordion (3/5) -->
      <div class="lg:col-span-3 space-y-3">
        {faqItems.map((item, i) => (
          <details class="group bg-white rounded-xl border border-neutral-200 overflow-hidden" open={i === 0 ? true : undefined}>
            <summary class="flex items-center justify-between cursor-pointer px-6 py-4 text-primary-900 font-medium text-base hover:bg-neutral-50 transition-colors min-h-[44px] list-none [&::-webkit-details-marker]:hidden">
              <span>{item.question}</span>
              <svg class="w-5 h-5 text-neutral-400 shrink-0 ml-4 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-neutral-700 text-sm leading-relaxed">
              {item.answer}
            </div>
          </details>
        ))}
      </div>

    </div>
  </div>
</section>
