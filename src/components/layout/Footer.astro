---
import { getSiteInfo } from '@data/content';
const siteInfo = getSiteInfo();
const year = new Date().getFullYear();
---

<footer class="bg-primary-950 text-neutral-100">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img src="/images/logo.jpeg" alt={`Logo ${siteInfo.name}`} class="h-12 w-auto rounded" width="48" height="48" />
          <span class="font-heading font-bold text-white text-xl">{siteInfo.name}</span>
        </div>
        <p class="text-neutral-300 text-sm leading-relaxed">
          Électricien qualifié intervenant sur le bassin grenoblois et le Nord Isère. Installation, rénovation, mise aux normes et climatisation.
        </p>
      </div>

      <!-- Coordonnées -->
      <div>
        <h3 class="font-heading font-semibold text-white text-lg mb-4">Coordonnées</h3>
        <ul class="space-y-3 text-sm">
          <li>
            <a href={`tel:+${siteInfo.whatsapp}`} class="text-neutral-300 hover:text-accent-400 transition-colors flex items-start gap-2" aria-label={`Appeler le ${siteInfo.phone}`}>
              <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              {siteInfo.phone}
            </a>
          </li>
          <li>
            <a href={`mailto:${siteInfo.email}`} class="text-neutral-300 hover:text-accent-400 transition-colors flex items-start gap-2" aria-label={`Envoyer un email à ${siteInfo.email}`}>
              <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              {siteInfo.email}
            </a>
          </li>
          <li class="text-neutral-300 flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            {siteInfo.address}, {siteInfo.postalCode} {siteInfo.city}
          </li>
        </ul>
      </div>

      <!-- Horaires + liens légaux -->
      <div>
        <h3 class="font-heading font-semibold text-white text-lg mb-4">Horaires</h3>
        <p class="text-neutral-300 text-sm mb-6">Lundi — Samedi : sur rendez-vous</p>

        <h3 class="font-heading font-semibold text-white text-lg mb-3">Informations légales</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/mentions-legales" class="text-neutral-300 hover:text-accent-400 transition-colors">Mentions légales</a></li>
          <li><a href="/politique-confidentialite" class="text-neutral-300 hover:text-accent-400 transition-colors">Politique de confidentialité</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-primary-800 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm">
      <p class="text-neutral-400">
        &copy; {year} {siteInfo.name} — Anthony Marques, électricien à {siteInfo.city} ({siteInfo.postalCode.substring(0, 2)})
      </p>
      <a href="https://marcm.fr/100-sites-artisans/" class="text-neutral-500 hover:text-neutral-300 transition-colors text-xs">
        Site réalisé par Marc M. · Spécialiste sites web pour électriciens
      </a>
    </div>
  </div>
</footer>
