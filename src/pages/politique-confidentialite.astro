---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import { getSiteInfo } from '@data/content';

const siteInfo = getSiteInfo();
const title = 'Politique de confidentialité — AM Électricité';
const description = "Politique de confidentialité et informations sur le traitement de vos données personnelles par AM Électricité.";
---

<BaseLayout title={title} description={description}>
  <Header slot="header" />

  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

      <h1 class="font-heading font-bold text-primary-900 text-3xl md:text-4xl mb-4">Politique de confidentialité</h1>
      <p class="text-neutral-500 text-sm mb-8">Dernière mise à jour : mars 2026</p>

      <div class="space-y-8 text-neutral-700 text-base leading-relaxed">

        <!-- Introduction -->
        <div>
          <h2 class="font-heading font-semibold text-primary-900 text-xl mb-3">Introduction</h2>
          <p>
            AM Électricité, représentée par Anthony Marques, s'engage à protéger la vie privée des visiteurs de son site <strong>am-electricite.fr</strong>. Cette politique détaille les données collectées, leur finalité et vos droits en vertu du Règlement Général sur la Protection des Données (RGPD).
          </p>
        </div>

        <!-- Responsable du traitement -->
        <div>
          <h2 class="font-heading font-semibold text-primary-900 text-xl mb-3">Responsable du traitement</h2>
          <ul class="space-y-1 text-sm">
            <li><strong>Nom :</strong> Anthony Marques — AM Électricité</li>
            <li><strong>Adresse :</strong> {siteInfo.address}, {siteInfo.postalCode} {siteInfo.city}</li>
            <li><strong>Email :</strong> <a href={`mailto:${siteInfo.email}`} class="text-primary-600 hover:underline">{siteInfo.email}</a></li>
            <li><strong>Téléphone :</strong> <a href={`tel:+${siteInfo.whatsapp}`} class="text-primary-600 hover:underline">{siteInfo.phone}</a></li>
          </ul>
        </div>

        <!-- Données collectées -->
        <div>
          <h2 class="font-heading font-semibold text-primary-900 text-xl mb-3">Données collectées</h2>
          <p>Les seules données personnelles collectées sur ce site proviennent du formulaire de contact :</p>
          <ul class="mt-2 space-y-1 text-sm list-disc list-inside">
            <li>Nom et prénom</li>
            <li>Numéro de téléphone ou adresse email</li>
            <li>Contenu du message (description du projet)</li>
          </ul>
          <p class="mt-2">Aucune autre donnée personnelle n'est collectée automatiquement. Ce site n'utilise pas de cookies de suivi, de pixels publicitaires ou de traceurs tiers.</p>
        </div>

        <!-- Finalité -->
        <div>
          <h2 class="font-heading font-semibold text-primary-900 text-xl mb-3">Finalité du traitement</h2>
          <p>Vos données sont utilisées exclusivement pour :</p>
          <ul class="mt-2 space-y-1 text-sm list-disc list-inside">
            <li>Répondre à votre demande de devis ou de renseignement</li>
            <li>Vous recontacter par téléphone ou email dans le cadre de votre projet</li>
          </ul>
          <p class="mt-2">Vos données ne sont jamais utilisées à des fins commerciales, publicitaires ou de prospection non sollicitée.</p>
        </div>

        <!-- Base légale -->
        <div>
          <h2 class="font-heading font-semibold text-primary-900 text-xl mb-3">Base légale</h2>
          <p>
            Le traitement de vos données repose sur votre <strong>consentement</strong>, matérialisé par la soumission volontaire du formulaire de contact (article 6.1.a du RGPD).
          </p>
        </div>

        <!-- Destinataires -->
        <div>
          <h2 class="font-heading font-semibold text-primary-900 text-xl mb-3">Destinataires des données</h2>
          <p>Vos données sont transmises exclusivement à :</p>
          <ul class="mt-2 space-y-1 text-sm list-disc list-inside">
            <li><strong>Anthony Marques</strong> (AM Électricité) — pour le traitement de votre demande</li>
            <li><strong>Web3Forms</strong> — service de transmission du formulaire (les données transitent par leurs serveurs pour la livraison par email, sans stockage permanent). <a href="https://web3forms.com/privacy" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">Politique de confidentialité Web3Forms</a></li>
          </ul>
          <p class="mt-2">Aucune donnée n'est vendue, louée ou partagée avec des tiers à des fins commerciales.</p>
        </div>

        <!-- Durée de conservation -->
        <div>
          <h2 class="font-heading font-semibold text-primary-900 text-xl mb-3">Durée de conservation</h2>
          <p>
            Les données collectées via le formulaire sont conservées dans la boîte email du responsable pour une durée maximale de <strong>3 ans</strong> à compter de votre dernier contact, ou jusqu'à votre demande de suppression.
          </p>
        </div>

        <!-- Cookies et analytics -->
        <div>
          <h2 class="font-heading font-semibold text-primary-900 text-xl mb-3">Cookies et mesure d'audience</h2>
          <p>
            Ce site utilise <strong>Umami Analytics</strong>, un outil de mesure d'audience respectueux de la vie privée. Umami :
          </p>
          <ul class="mt-2 space-y-1 text-sm list-disc list-inside">
            <li>Ne dépose <strong>aucun cookie</strong> sur votre navigateur</li>
            <li>Ne collecte <strong>aucune donnée personnelle identifiable</strong></li>
            <li>Ne suit pas les visiteurs entre les sessions ou les sites</li>
            <li>Est conforme au RGPD sans nécessiter de consentement préalable</li>
          </ul>
          <p class="mt-2">En conséquence, <strong>aucune bannière de consentement aux cookies n'est nécessaire</strong> sur ce site.</p>
        </div>

        <!-- Droits -->
        <div>
          <h2 class="font-heading font-semibold text-primary-900 text-xl mb-3">Vos droits</h2>
          <p>Conformément au RGPD, vous disposez des droits suivants :</p>
          <ul class="mt-2 space-y-1 text-sm list-disc list-inside">
            <li><strong>Droit d'accès :</strong> obtenir la confirmation du traitement de vos données et en demander une copie</li>
            <li><strong>Droit de rectification :</strong> corriger des données inexactes ou incomplètes</li>
            <li><strong>Droit à l'effacement :</strong> demander la suppression de vos données</li>
            <li><strong>Droit à la portabilité :</strong> recevoir vos données dans un format structuré et lisible</li>
            <li><strong>Droit d'opposition :</strong> vous opposer au traitement de vos données</li>
            <li><strong>Droit de retrait du consentement :</strong> retirer votre consentement à tout moment</li>
          </ul>
          <p class="mt-3">
            Pour exercer ces droits, contactez-nous à : <a href={`mailto:${siteInfo.email}`} class="text-primary-600 hover:underline">{siteInfo.email}</a>
          </p>
          <p class="mt-2">
            Vous avez également le droit d'introduire une réclamation auprès de la <strong>CNIL</strong> (Commission Nationale de l'Informatique et des Libertés) : <a href="https://www.cnil.fr" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">www.cnil.fr</a>
          </p>
        </div>

        <!-- Services tiers -->
        <div>
          <h2 class="font-heading font-semibold text-primary-900 text-xl mb-3">Services tiers</h2>
          <ul class="space-y-2 text-sm">
            <li><strong>Cloudflare</strong> — hébergement et CDN. Peut traiter des données techniques (adresse IP) pour la sécurité et la performance. <a href="https://www.cloudflare.com/privacypolicy/" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">Politique de confidentialité</a></li>
            <li><strong>Web3Forms</strong> — transmission des formulaires. <a href="https://web3forms.com/privacy" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">Politique de confidentialité</a></li>
            <li><strong>Umami Cloud</strong> — analytics sans cookies. <a href="https://umami.is/privacy" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">Politique de confidentialité</a></li>
          </ul>
        </div>

        <!-- Modification -->
        <div>
          <h2 class="font-heading font-semibold text-primary-900 text-xl mb-3">Modification de cette politique</h2>
          <p>
            Cette politique de confidentialité peut être mise à jour à tout moment. La date de dernière mise à jour est indiquée en haut de cette page. Nous vous invitons à la consulter régulièrement.
          </p>
        </div>

      </div>

      <!-- Back link -->
      <div class="mt-12 pt-8 border-t border-neutral-200">
        <a href="/" class="text-primary-700 hover:text-primary-600 font-medium text-sm transition-colors flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16l-4-4m0 0l4-4m-4 4h18"/></svg>
          Retour à l'accueil
        </a>
      </div>

    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
