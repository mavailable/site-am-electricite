---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import { getSiteInfo } from '@data/content';

const siteInfo = getSiteInfo();
const title = 'Merci — AM Électricité';
const description = 'Votre demande de devis a bien été envoyée. Anthony vous répondra sous 24 heures.';
---

<BaseLayout title={title} description={description} noIndex={true}>
  <Header slot="header" />

  <section class="py-20 md:py-32 bg-white">
    <div class="max-w-lg mx-auto px-4 text-center">
      <!-- Success icon -->
      <div class="w-16 h-16 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <h1 class="font-heading font-bold text-primary-900 text-3xl md:text-4xl mb-4">
        Merci pour votre message !
      </h1>

      <p class="text-neutral-700 text-lg leading-relaxed mb-4">
        Votre demande a bien été envoyée. Anthony vous répondra sous 24 heures.
      </p>

      <p class="text-neutral-600 text-base mb-8">
        En attendant, n'hésitez pas à appeler directement au
        <a href={`tel:+${siteInfo.whatsapp}`} class="text-primary-600 font-medium hover:underline">{siteInfo.phone}</a>
        pour toute question urgente.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center bg-accent-400 text-secondary-950 font-bold py-3 px-6 rounded-lg hover:bg-accent-500 transition-all min-h-[44px]"
        >
          Retourner à l'accueil
        </a>
        <a
          href={`https://wa.me/${siteInfo.whatsapp}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 bg-[#19773E] text-white font-bold py-3 px-6 rounded-lg hover:bg-[#155E30] transition-all min-h-[44px]"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Écrire sur WhatsApp
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
