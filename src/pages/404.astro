---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import { getSiteInfo } from '@data/content';

const siteInfo = getSiteInfo();
const title = 'Page introuvable — AM Électricité';
const description = "La page que vous cherchez n'existe pas. Retournez sur le site AM Électricité pour trouver un électricien à Grenoble.";
---

<BaseLayout title={title} description={description} noIndex={true}>
  <Header slot="header" />

  <section class="py-20 md:py-32 bg-white">
    <div class="max-w-lg mx-auto px-4 text-center">
      <p class="font-heading font-bold text-primary-200 text-8xl mb-4">404</p>

      <h1 class="font-heading font-bold text-primary-900 text-2xl md:text-3xl mb-4">
        Page introuvable
      </h1>

      <p class="text-neutral-700 text-base leading-relaxed mb-8">
        La page que vous cherchez n'existe pas ou a été déplacée.
        Pas de panique, voici quelques liens utiles pour vous orienter.
      </p>

      <!-- Quick links -->
      <nav class="flex flex-wrap justify-center gap-3 mb-8" aria-label="Liens rapides">
        <a href="/#services" class="text-primary-700 hover:text-primary-600 font-medium text-sm underline underline-offset-2 transition-colors">Services</a>
        <a href="/#realisations" class="text-primary-700 hover:text-primary-600 font-medium text-sm underline underline-offset-2 transition-colors">Réalisations</a>
        <a href="/#faq" class="text-primary-700 hover:text-primary-600 font-medium text-sm underline underline-offset-2 transition-colors">FAQ</a>
        <a href="/#contact" class="text-primary-700 hover:text-primary-600 font-medium text-sm underline underline-offset-2 transition-colors">Contact</a>
      </nav>

      <a
        href="/"
        class="inline-flex items-center justify-center bg-accent-400 text-secondary-950 font-bold py-3 px-6 rounded-lg hover:bg-accent-500 transition-all min-h-[44px]"
      >
        Retourner à l'accueil
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
